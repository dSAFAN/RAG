# ====================================================================
# Vector Databases & Local Storage (ChromaDB)
# ====================================================================
# Protects against committing local vector indexes and binary database files
chroma/
chromadb/
chroma_db/
*.db
*.sqlite3
db/

# ====================================================================
# Secrets & Environment Variables
# ====================================================================
# Extremely crucial to prevent leaking your Mistral or Hugging Face API keys
.env
.env.local
.env.secret

# ====================================================================
# Python & Virtual Environments
# ====================================================================
.venv/
venv/
ENV/
__pycache__/
*.py[cod]
*$py.class

# ====================================================================
# Local LLM & Embedding Model Caches
# ====================================================================
# Prevents committing heavy downloaded Hugging Face weights to Git
.cache/
huggingface_cache/
.huggingface/

# ====================================================================
# IDEs and Operating System Artifacts
# ====================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db

*.txt
*.pdf